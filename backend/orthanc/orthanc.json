{
  // Orthanc 配置（backend/orthanc/orthanc.json）
  // 启动方式：docker compose up -d orthanc
  // 文档：https://orthanc.uclouvain.be/book/users/configuration.html

  // ───── 基本信息 ─────────────────────────────────────────
  "Name": "MediScribe-PACS",
  "DicomAet": "MEDISCRIBE",
  "HttpPort": 8042,
  "DicomPort": 4242,
  "DicomCheckCalledAet": false,
  "RemoteAccessAllowed": true,

  // ───── 鉴权（基础认证）─────────────────────────────────
  // 用户名密码不在本文件硬编码——由 docker-compose.yml 的环境变量
  // ORTHANC__REGISTERED_USERS__MEDISCRIBE=${ORTHANC_PASSWORD} 注入。
  // Orthanc 25+ 支持 ENV 覆盖 JSON 配置（_SECTION__KEY 双下划线 = . 分层）。
  // 这样仓库里不留任何能直接登录 Orthanc 的密码。
  "AuthenticationEnabled": true,
  "RegisteredUsers": {},

  // ───── DICOMweb 插件（核心，让 FastAPI/OHIF 走标准协议）─
  "DicomWeb": {
    "Enable": true,
    "Root": "/dicom-web/",
    "EnableWado": true,
    "WadoRoot": "/wado",
    "Ssl": false,
    "QidoCaseSensitive": false
  },

  // ───── PostgreSQL 索引（复用项目主 PG）──────────────────
  // 文件本身存文件系统（更快），元数据/索引存 PG（便于查询、备份与项目主库一致）
  "PostgreSQL": {
    "EnableIndex": true,
    "EnableStorage": false,
    "Host": "db",
    "Port": 5432,
    "Database": "orthanc",
    // Username / Password 由 docker-compose 注入（ORTHANC__POSTGRESQL__USERNAME /
    // ORTHANC__POSTGRESQL__PASSWORD = ${DB_USER} / ${DB_PASSWORD}），不在本文件硬编码
    "EnableSsl": false,
    "Lock": false
  },

  // ───── 文件存储 ─────────────────────────────────────────
  // /var/lib/orthanc/db 由 docker volume 挂载到宿主机
  "StorageDirectory": "/var/lib/orthanc/db",
  "IndexDirectory": "/var/lib/orthanc/db",

  // ───── CORS（让前端 OHIF 能直接 fetch）─────────────────
  "HttpHeaders": {
    "Access-Control-Allow-Origin": "*",
    "Access-Control-Allow-Methods": "GET,POST,PUT,DELETE,OPTIONS",
    "Access-Control-Allow-Headers": "Authorization,Content-Type,Accept,Origin,X-Requested-With"
  },

  // ───── 其他 ─────────────────────────────────────────────
  "ConcurrentJobs": 4,
  "JobsHistorySize": 30,
  "LogLevel": "default"
}
