# ── 数据库（必填，无默认值——docker compose 启动时若未设置会立即报错）─────
# 必须改成强密码（建议 32+ 字符随机串）：python -c "import secrets; print(secrets.token_urlsafe(32))"
DB_USER=medassist
DB_PASSWORD=<请改成强密码>
DATABASE_URL=postgresql+asyncpg://medassist:<请改成强密码>@localhost:5432/medassist

# ── Orthanc DICOM 服务器（必填，无默认值）────────────────────────────────────
# Orthanc HTTP Basic Auth 凭证。docker-compose.yml 通过环境变量注入，
# 不再硬编码到 backend/orthanc/orthanc.json 里（防止公网仓库泄露）。
# 必须改成强密码（≠ DB_PASSWORD，独立轮换）。
ORTHANC_USERNAME=mediscribe
ORTHANC_PASSWORD=<请改成强密码>
# backend 容器访问 Orthanc 的地址（docker compose 内网走服务名）
ORTHANC_BASE_URL=http://orthanc:8042

# ── 安全 ─────────────────────────────────────────────────────────────────────
# JWT 签名密钥，必填——生产环境必须替换为随机 32+ 位字符串：
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<请改成 32 位以上随机串>
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── AI 模型（主力：DeepSeek）─────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── AI 模型（备用：阿里云 / 通义千问，可选）──────────────────────────────────
# 留空则不启用阿里云模型
ALIYUN_API_KEY=sk-xxxxxxxxxxxxxxxx

# ── 跨域 ─────────────────────────────────────────────────────────────────────
# 多个来源用逗号分隔，部署后改为实际域名
ALLOWED_ORIGINS=http://localhost,http://localhost:5174

# ── 错误监控（Sentry）────────────────────────────────────────────────────────
# 留空 = 不启用 Sentry（本地开发默认行为，避免污染生产项目）
# DSN 形如：https://xxx@xxx.ingest.sentry.io/yyy
SENTRY_DSN=
# 环境标识，告警分流用：development / staging / production
# 不填则自动用 APP_ENV 的值
SENTRY_ENVIRONMENT=
# 性能 trace 采样率（0~1）：开发置 0，生产建议 0.05
SENTRY_TRACES_SAMPLE_RATE=0.0
# release 标识（CI deploy 自动注入 git SHA，本地开发无需配置）
SENTRY_RELEASE=
