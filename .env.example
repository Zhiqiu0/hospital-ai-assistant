# ── 数据库 ──────────────────────────────────────────────────────────────────
# Docker Compose 默认用 postgres 服务，生产环境替换为实际连接字符串
DB_PASSWORD=medassist123
DATABASE_URL=postgresql+asyncpg://medassist:medassist123@localhost:5432/medassist

# ── 安全 ─────────────────────────────────────────────────────────────────────
# 生产环境必须替换为随机长字符串：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── AI 模型（主力：DeepSeek）─────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── AI 模型（备用：阿里云 / 通义千问，可选）──────────────────────────────────
# 留空则不启用阿里云模型
ALIYUN_API_KEY=sk-xxxxxxxxxxxxxxxx

# ── 跨域 ─────────────────────────────────────────────────────────────────────
# 多个来源用逗号分隔，部署后改为实际域名
ALLOWED_ORIGINS=http://localhost,http://localhost:5174

# ── 错误监控（Sentry）────────────────────────────────────────────────────────
# 留空 = 不启用 Sentry（本地开发默认行为，避免污染生产项目）
# DSN 形如：https://xxx@xxx.ingest.sentry.io/yyy
SENTRY_DSN=
# 环境标识，告警分流用：development / staging / production
# 不填则自动用 APP_ENV 的值
SENTRY_ENVIRONMENT=
# 性能 trace 采样率（0~1）：开发置 0，生产建议 0.05
SENTRY_TRACES_SAMPLE_RATE=0.0
# release 标识（CI deploy 自动注入 git SHA，本地开发无需配置）
SENTRY_RELEASE=
